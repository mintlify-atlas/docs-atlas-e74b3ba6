  "keyFeatures": [
    "Work orchestration with organizations, boards, tasks, and tags",
    "Agent lifecycle management with provisioning and monitoring",
    "Gateway-aware orchestration for distributed environments",
    "Approval-driven governance with human-in-the-loop workflows",
    "Activity timeline and audit trail for accountability",
    "Real-time updates via SSE streams",
    "Webhook integrations with retry logic",
    "Skills marketplace and agent templates",
    "Board and board group memory management",
    "Multi-tenant architecture with role-based access control",
    "Template synchronization for agent configuration",
    "Session management and chat history"
  ],
